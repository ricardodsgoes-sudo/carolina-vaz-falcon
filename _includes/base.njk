<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ===================== SEO ===================== -->
  <title>{{ title }} — {{ site.name }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="author" content="{{ site.author }}" />
  <meta name="theme-color" content="#FBF7F0" />

  {% set ogImg = cover or '/assets/images/sobre-carolina.webp' %}
  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content="{{ title }} — {{ site.name }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:image" content="{{ ogImg }}" />
  <meta property="og:locale" content="pt_BR" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- Favicon -->
  <link rel="icon" type="image/webp" href="/assets/images/tree-gold.webp" />

  <!-- Fonts: Cormorant Garamond (display) + Jost (texto/UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Mesmos tokens/estilos do site + folha específica do blog -->
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/blog.css" />
</head>

<body>
  <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>

  <!-- ============================================================= -->
  <!-- HEADER — mesmo componente do site (links absolutos p/ a home)  -->
  <!-- ============================================================= -->
  <header class="header" id="header" data-header>
    <div class="container header__inner">

      <a class="brand" href="/" aria-label="{{ site.name }} — Psicóloga — página inicial">
        <img class="brand__emblem" src="/assets/images/tree-gold.webp" alt="" width="44" height="45" aria-hidden="true" />
        <span class="brand__text">
          <span class="brand__name">{{ site.name }}</span>
          <span class="brand__role">Psicóloga · {{ site.crp }}</span>
        </span>
      </a>

      <nav class="nav" aria-label="Navegação principal">
        <a class="nav__link" href="/#hero">Início</a>
        <a class="nav__link" href="/#atendimentos">Atendimentos</a>
        <a class="nav__link" href="/#abordagem">Abordagem</a>
        <a class="nav__link" href="/#sobre">Sobre mim</a>
        <a class="nav__link" href="/blog/" aria-current="page">Blog</a>
        <a class="nav__link" href="/#contato">Contato</a>
      </nav>

      <a class="btn btn--gold header__cta" href="{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer">
        <span>Agendar conversa</span>
      </a>

      <button class="nav-toggle" id="navToggle" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>

    <nav class="mobile-menu" id="mobileMenu" aria-label="Navegação mobile" hidden>
      <a class="mobile-menu__link" href="/#hero">Início</a>
      <a class="mobile-menu__link" href="/#atendimentos">Atendimentos</a>
      <a class="mobile-menu__link" href="/#abordagem">Abordagem</a>
      <a class="mobile-menu__link" href="/#sobre">Sobre mim</a>
      <a class="mobile-menu__link" href="/blog/" aria-current="page">Blog</a>
      <a class="mobile-menu__link" href="/#contato">Contato</a>
      <a class="btn btn--gold mobile-menu__cta" href="{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer">Agendar conversa</a>
    </nav>
  </header>

  <!-- ============================================================= -->
  <!-- CONTEÚDO DO BLOG                                               -->
  <!-- ============================================================= -->
  <main class="blog-main" id="conteudo">
    {{ content | safe }}
  </main>

  <!-- ============================================================= -->
  <!-- FOOTER — mesmo componente do site                             -->
  <!-- ============================================================= -->
  <footer class="footer">
    <div class="container footer__inner">

      <div class="footer__brand">
        <img class="footer__emblem" src="/assets/images/logo-branca.svg" alt="" width="56" height="56" aria-hidden="true" />
        <p class="footer__name">{{ site.name }}</p>
        <p class="footer__role">Psicóloga · {{ site.crp }}</p>
        <p class="footer__tagline">Psicologia • Gestalt-terapia • Neurociência • Cuidado Integral em Saúde Emocional</p>
      </div>

      <nav class="footer__col" aria-label="Navegação do rodapé">
        <h2 class="footer__col-title">Navegação</h2>
        <a href="/#hero">Início</a>
        <a href="/#atendimentos">Atendimentos</a>
        <a href="/#abordagem">Abordagem</a>
        <a href="/#sobre">Sobre mim</a>
        <a href="/blog/">Blog</a>
        <a href="/#contato">Contato</a>
      </nav>

      <div class="footer__col">
        <h2 class="footer__col-title">Contato</h2>
        <a href="{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer">WhatsApp (62) 98104-6311</a>
        <a href="https://instagram.com/psi.carolinavaz" target="_blank" rel="noopener noreferrer">@psi.carolinavaz</a>
      </div>

      <div class="footer__col">
        <h2 class="footer__col-title">Atendimento</h2>
        <p>Presencial — Aparecida de Goiânia/GO</p>
        <p>Online — Google Meet</p>
      </div>

      <div class="footer__bottom">
        <p class="footer__note">Conteúdo informativo; não substitui avaliação ou atendimento profissional individualizado.</p>
        <p class="footer__copy">© <span id="year">2026</span> {{ site.name }} · Aparecida de Goiânia/GO</p>
      </div>
    </div>
  </footer>

  <!-- Botão flutuante WhatsApp -->
  <a class="wa-float" href="{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer" aria-label="Conversar pelo WhatsApp">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.34 4.97L2 22l5.25-1.38a9.9 9.9 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91A9.9 9.9 0 0 0 12.04 2Zm5.82 14.15c-.25.7-1.45 1.34-2.03 1.42-.52.08-1.18.11-1.9-.12-.44-.14-1-.32-1.72-.63-3.02-1.3-4.99-4.34-5.14-4.54-.15-.2-1.23-1.64-1.23-3.13s.78-2.22 1.06-2.52c.28-.3.6-.38.8-.38h.58c.18 0 .43-.07.67.51.25.6.85 2.08.93 2.23.08.15.13.33.03.53-.1.2-.15.33-.3.5-.15.18-.32.39-.45.52-.15.15-.31.31-.13.61.18.3.8 1.32 1.72 2.14 1.18 1.05 2.18 1.38 2.48 1.53.3.15.48.13.65-.08.18-.2.75-.88.95-1.18.2-.3.4-.25.68-.15.28.1 1.78.84 2.08.99.3.15.5.23.58.35.08.13.08.73-.17 1.43Z" fill="currentColor" stroke="none"/></svg>
  </a>

  <!-- Bibliotecas (CDN) — mesmas do site, p/ navbar e scroll suave -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
