---
layout: base.njk
---
<article class="post container">

  <a class="post__back" href="/blog/">
    <span aria-hidden="true">←</span> Voltar ao blog
  </a>

  <header class="post__header">
    <p class="eyebrow eyebrow--center">Blog</p>
    <h1 class="post__title">{{ title }}</h1>
    <p class="post__date">
      <time datetime="{{ date | isoData }}">{{ date | dataPt }}</time>
    </p>
  </header>

  {% if cover %}
  <figure class="post__cover-wrap" data-animate>
    <img class="post__cover" src="{{ cover }}" alt="{{ title }}" width="1200" height="675" />
  </figure>
  {% endif %}

  <div class="prose">
    {{ content | safe }}
  </div>

  <footer class="post__foot">
    <p class="post__note">
      Conteúdo informativo; não substitui avaliação ou atendimento profissional individualizado.
    </p>
    <a class="btn btn--gold btn--lg" href="{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer">
      <svg class="ico ico--wa" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.34 4.97L2 22l5.25-1.38a9.9 9.9 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91A9.9 9.9 0 0 0 12.04 2Zm5.82 14.15c-.25.7-1.45 1.34-2.03 1.42-.52.08-1.18.11-1.9-.12-.44-.14-1-.32-1.72-.63-3.02-1.3-4.99-4.34-5.14-4.54-.15-.2-1.23-1.64-1.23-3.13s.78-2.22 1.06-2.52c.28-.3.6-.38.8-.38h.58c.18 0 .43-.07.67.51.25.6.85 2.08.93 2.23.08.15.13.33.03.53-.1.2-.15.33-.3.5-.15.18-.32.39-.45.52-.15.15-.31.31-.13.61.18.3.8 1.32 1.72 2.14 1.18 1.05 2.18 1.38 2.48 1.53.3.15.48.13.65-.08.18-.2.75-.88.95-1.18.2-.3.4-.25.68-.15.28.1 1.78.84 2.08.99.3.15.5.23.58.35.08.13.08.73-.17 1.43Z"/></svg>
      Agendar conversa pelo WhatsApp
    </a>
  </footer>
</article>

<!-- Schema.org — artigo do blog -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "image": {{ (cover or '/assets/images/sobre-carolina.webp') | dump | safe }},
  "datePublished": {{ (date | isoData) | dump | safe }},
  "inLanguage": "pt-BR",
  "author": { "@type": "Person", "name": {{ site.author | dump | safe }} },
  "publisher": { "@type": "Person", "name": {{ site.author | dump | safe }} }
}
</script>
